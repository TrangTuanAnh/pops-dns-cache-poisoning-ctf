# Bailiwick Breakout 2 checker config.
#
# The docker-compose file mounts ./expected_solution.json into the
# container and app.py reads it through EXPECTED_SOLUTION_FILE by default.
#
# For a custom deployment without the mounted file, set either:
# EXPECTED_SOLUTION_JSON={"victim_domain":"...","malicious_ns":"...",...}
#
# or set all individual fields:
# VICTIM_DOMAIN=bank.victim.com
# MALICIOUS_NS=ns.evilcorp.example
# MALICIOUS_NS_IP=6.6.6.6
# TRIGGER_QNAME=promo.attacker.net
# POISON_PACKET_NUMBER=0
# POISON_DNS_TXID=0x0000
# FIRST_CACHE_SEEN=2026-05-21T10:03:14Z
# FIRST_VICTIM_QUERY=2026-05-21T10:07:18Z
#
# Set this only when the checker is behind a trusted reverse proxy that owns
# X-Forwarded-For. Leave false/direct for local Docker.
# TRUST_PROXY=false

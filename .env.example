COMPOSE_PROJECT_NAME=pops-ctf

# Scope 3-flag B (deterministic). Replace placeholder voi gia tri team thuc khi
# run real event.
FLAG_1B=flag{dev_stage1b_placeholder}
FLAG_2B=flag{dev_stage2b_placeholder}
FLAG_3B=flag{dev_stage3b_placeholder}

POPS_TAU=5
POPS_WINDOW=1.0
POPS_CMS_W=200
POPS_CMS_D=5

# Stage 2: lower threshold de Rl2 trip ngay ca cho A query nho. Day la
# lab simplification giup demo TCP fallback compat ma khong can dung TXT
# query. Set 1232 (paper default) neu test fragmentation thuc su voi
# query TXT padding.
POPS_FRAG_THRESHOLD=50

# Stage 2 non-compliant resolver: servfail | timeout | drop
NON_COMPLIANT_BEHAVIOR=servfail
